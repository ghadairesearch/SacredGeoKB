<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:sgkb="https://github.com/ghadairesearch/SacredGeoKB#"><owl:Ontology rdf:about="https://github.com/ghadairesearch/SacredGeoKB"><rdfs:label>SacredGeoKB Hajj and Sacred Geography Ontology</rdfs:label><rdfs:comment>OWL/RDF export generated from hajj-ontology.jsonld and linked to SacredGeoKB GeoJSON spatial zones.</rdfs:comment></owl:Ontology><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#alternative_labels" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#associated_zone_ids" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#ayah_number" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#comment" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#context_state" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#creator" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#data_identifier" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#definition" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#definition_ar" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#domain" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#end_zone_id" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#evidence_required" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#example" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#inferred_need" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#journey_type" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#keywords" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#knowledge_intent" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#label_ar" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#label_en" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#movement_rule" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#notes" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#outside_zone_ids" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#pillar_order" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#priority" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#publication_date" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#publisher" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#quran_reference" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#range" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#recommended_message_type" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#required_rounds" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#round_count_rule" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#sequence_rule" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#source_zone_id" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#spatial_rule" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#spatial_stage" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#spatial_zone_type" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#special_rules" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#start_zone_id" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#summary" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#surah_name_ar" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#surah_name_en" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#surah_number" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#temporal_rule" /><owl:AnnotationProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#title" /><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#associated_occasion"><rdfs:label xml:lang="en">associated occasion</rdfs:label><rdfs:label xml:lang="ar">يرتبط بمناسبة</rdfs:label><rdfs:comment>Connects a ritual to the religious occasion or time window in which it is primarily performed.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#associated_place"><rdfs:label xml:lang="en">associated place</rdfs:label><rdfs:label xml:lang="ar">يرتبط بمكان</rdfs:label><rdfs:comment>Connects a ritual or religious occasion to the sacred or Hajj place where it is performed or primarily associated.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#contains_place"><rdfs:label xml:lang="en">contains place</rdfs:label><rdfs:label xml:lang="ar">تضم مكانًا</rdfs:label><rdfs:comment>Connects a city concept to the sacred or Hajj places located within it.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#follows"><rdfs:label xml:lang="en">follows</rdfs:label><rdfs:label xml:lang="ar">يتبع</rdfs:label><rdfs:comment>Connects an entity to another entity that usually occurs before it in the ritual or temporal sequence.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#gate_of"><rdfs:label xml:lang="en">gate of</rdfs:label><rdfs:label xml:lang="ar">باب لـ</rdfs:label><rdfs:comment>Connects a gate spatial semantic node to the mosque or sacred place it belongs to.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#has_gate"><rdfs:label xml:lang="en">has gate</rdfs:label><rdfs:label xml:lang="ar">له باب</rdfs:label><rdfs:comment>Connects a mosque or sacred place to the gate spatial semantic nodes that belong to it.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#has_occasion"><rdfs:label xml:lang="en">has occasion</rdfs:label><rdfs:label xml:lang="ar">يتضمن مناسبة</rdfs:label><rdfs:comment>Connects a pilgrimage journey to a religious occasion that occurs during that journey.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#has_ritual"><rdfs:label xml:lang="en">has ritual</rdfs:label><rdfs:label xml:lang="ar">يتضمن نسكًا</rdfs:label><rdfs:comment>Connects a pilgrimage journey to one or more rituals that belong to that journey.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#has_sub_ritual"><rdfs:label xml:lang="en">has sub ritual</rdfs:label><rdfs:label xml:lang="ar">يتضمن نسكًا فرعيًا</rdfs:label><rdfs:comment>Connects a general ritual to a more specific ritual type under it.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#islam_pillar"><rdfs:label xml:lang="en">Islam pillar</rdfs:label><rdfs:label xml:lang="ar">ركن إسلامي</rdfs:label><rdfs:comment>Connects an ontology concept such as HajjJourney to the corresponding pillar of Islam.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#located_in_city"><rdfs:label xml:lang="en">located in city</rdfs:label><rdfs:label xml:lang="ar">يقع في مدينة</rdfs:label><rdfs:comment>Connects a sacred or Hajj place to the city where it is located.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#mentioned_in_quran"><rdfs:label xml:lang="en">mentioned in Quran</rdfs:label><rdfs:label xml:lang="ar">مذكور في القرآن</rdfs:label><rdfs:comment>Connects an ontology concept to a Quran verse where the concept is mentioned or directly referenced.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#mentions_concept"><rdfs:label xml:lang="en">mentions concept</rdfs:label><rdfs:label xml:lang="ar">تذكر مفهومًا</rdfs:label><rdfs:comment>Connects a Quran verse to ontology concepts mentioned or directly referenced by the verse.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#part_of"><rdfs:label xml:lang="en">part of</rdfs:label><rdfs:label xml:lang="ar">جزء من</rdfs:label><rdfs:comment>Connects a religious occasion, sacred place, or Hajj place to the larger journey or conceptual entity it belongs to.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#performed_in_city"><rdfs:label xml:lang="en">performed in city</rdfs:label><rdfs:label xml:lang="ar">يؤدى في مدينة</rdfs:label><rdfs:comment>Connects a journey or ritual concept to the city where it is primarily performed.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#precedes"><rdfs:label xml:lang="en">precedes</rdfs:label><rdfs:label xml:lang="ar">يسبق</rdfs:label><rdfs:comment>Connects an entity to another entity that usually occurs after it in the ritual or temporal sequence.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#represented_by"><rdfs:label xml:lang="en">represented by</rdfs:label><rdfs:label xml:lang="ar">يمثله</rdfs:label><rdfs:comment>Connects a conceptual pillar to the ontology node that operationalizes it.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#ritual_of"><rdfs:label xml:lang="en">ritual of</rdfs:label><rdfs:label xml:lang="ar">نسك من</rdfs:label><rdfs:comment>Connects a ritual to the pilgrimage journey in which the ritual is performed.</rdfs:comment></owl:ObjectProperty><owl:ObjectProperty rdf:about="https://github.com/ghadairesearch/SacredGeoKB#sub_ritual_of"><rdfs:label xml:lang="en">sub ritual of</rdfs:label><rdfs:label xml:lang="ar">نسك فرعي من</rdfs:label><rdfs:comment>Connects a specific ritual type to the broader ritual category it belongs to.</rdfs:comment></owl:ObjectProperty><owl:Class rdf:about="https://github.com/ghadairesearch/SacredGeoKB#HajjPlace" /><owl:Class rdf:about="https://github.com/ghadairesearch/SacredGeoKB#IslamPillar"><rdfs:label xml:lang="en">Pillar of Islam</rdfs:label><rdfs:label xml:lang="ar">ركن من أركان الإسلام</rdfs:label><rdfs:comment>One of the five foundational pillars of Islam.</rdfs:comment></owl:Class><owl:Class rdf:about="https://github.com/ghadairesearch/SacredGeoKB#Journey"><rdfs:label xml:lang="en">Journey</rdfs:label><rdfs:label xml:lang="ar">رحلة</rdfs:label><rdfs:comment>A structured pilgrimage or visit path performed by the user.</rdfs:comment></owl:Class><owl:Class rdf:about="https://github.com/ghadairesearch/SacredGeoKB#QuranVerse"><rdfs:label xml:lang="en">Quran Verse</rdfs:label><rdfs:label xml:lang="ar">آية قرآنية</rdfs:label><rdfs:comment>A Quran verse referenced by ontology concepts.</rdfs:comment></owl:Class><owl:Class rdf:about="https://github.com/ghadairesearch/SacredGeoKB#RelationshipProperty"><rdfs:label xml:lang="en">Relationship Property</rdfs:label><rdfs:label xml:lang="ar">خاصية علاقة</rdfs:label><rdfs:comment>A semantic relation used to connect ontology entities such as journeys, rituals, occasions, and places.</rdfs:comment></owl:Class><owl:Class rdf:about="https://github.com/ghadairesearch/SacredGeoKB#ReligiousOccasion"><rdfs:label xml:lang="en">Religious Occasion</rdfs:label><rdfs:label xml:lang="ar">مناسبة دينية</rdfs:label><rdfs:comment>A religiously significant time window in the Hajj journey.</rdfs:comment></owl:Class><owl:Class rdf:about="https://github.com/ghadairesearch/SacredGeoKB#Ritual"><rdfs:label xml:lang="en">Ritual</rdfs:label><rdfs:label xml:lang="ar">نسك</rdfs:label><rdfs:comment>A worship action or ritual state in the pilgrimage journey.</rdfs:comment></owl:Class><owl:Class rdf:about="https://github.com/ghadairesearch/SacredGeoKB#SacredPlace" /><owl:Class rdf:about="https://github.com/ghadairesearch/SacredGeoKB#SpatialZoneSemantic"><rdfs:label xml:lang="en">Spatial Zone Semantic Metadata</rdfs:label><rdfs:label xml:lang="ar">بيانات دلالية للنطاق المكاني</rdfs:label><rdfs:comment>Ontology node that stores the semantic type and suggested spatial stage for a spatial geofence.</rdfs:comment></owl:Class><owl:NamedIndividual rdf:about="https://github.com/ghadairesearch/SacredGeoKB#HajjJourney"><rdf:type rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Journey" /><sgkb:label_en>Hajj Journey</sgkb:label_en><sgkb:label_ar>رحلة الحج</sgkb:label_ar><sgkb:definition>The pilgrimage journey performed during the Hajj season.</sgkb:definition><sgkb:journey_type>hajj</sgkb:journey_type><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#AlIhram" /><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Tawaf" /><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Sai" /><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#StandingInArafat" /><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#SpendingNightInMuzdalifah" /><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Rami" /><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#HairShaving" /><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#SpendingNightInMina" /><sgkb:has_occasion rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#DayOfTarwiyah" /><sgkb:has_occasion rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#DayOfArafat" /><sgkb:has_occasion rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#MuzdalifahNight" /><sgkb:has_occasion rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#EidAlAdha" /><sgkb:has_occasion rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#FirstTashreeqNight" /><sgkb:has_occasion rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#DaysOfTashreeq" /><sgkb:mentioned_in_quran rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#QuranVerse_22_27" /><sgkb:islam_pillar rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#HajjPillar" /><sgkb:performed_in_city rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#MakkahCity" /><sgkb:creator>Ghader Kurdi</sgkb:creator><sgkb:title>Hajj Journey</sgkb:title><sgkb:data_identifier>HajjJourney</sgkb:data_identifier><sgkb:publisher>Ghader Kurdi</sgkb:publisher><sgkb:publication_date>2026-07-11</sgkb:publication_date><sgkb:summary>The pilgrimage journey performed during the Hajj season.</sgkb:summary><sgkb:keywords>Journey</sgkb:keywords><sgkb:keywords>HajjJourney</sgkb:keywords><sgkb:keywords>Hajj Journey</sgkb:keywords><sgkb:keywords>رحلة الحج</sgkb:keywords><sgkb:keywords>hajj</sgkb:keywords></owl:NamedIndividual><owl:NamedIndividual rdf:about="https://github.com/ghadairesearch/SacredGeoKB#UmrahJourney"><rdf:type rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Journey" /><sgkb:label_en>Umrah Journey</sgkb:label_en><sgkb:label_ar>رحلة العمرة</sgkb:label_ar><sgkb:definition>The pilgrimage journey centered on Ihram, Tawaf, and Sa'i outside the full Hajj sequence.</sgkb:definition><sgkb:journey_type>umrah</sgkb:journey_type><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#AlIhram" /><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Tawaf" /><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Sai" /><sgkb:has_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#HairShaving" /><sgkb:creator>Ghader Kurdi</sgkb:creator><sgkb:title>Umrah Journey</sgkb:title><sgkb:data_identifier>UmrahJourney</sgkb:data_identifier><sgkb:publisher>Ghader Kurdi</sgkb:publisher><sgkb:publication_date>2026-07-11</sgkb:publication_date><sgkb:summary>The pilgrimage journey centered on Ihram, Tawaf, and Sa'i outside the full Hajj sequence.</sgkb:summary><sgkb:keywords>Journey</sgkb:keywords><sgkb:keywords>UmrahJourney</sgkb:keywords><sgkb:keywords>Umrah Journey</sgkb:keywords><sgkb:keywords>رحلة العمرة</sgkb:keywords><sgkb:keywords>umrah</sgkb:keywords></owl:NamedIndividual><owl:NamedIndividual rdf:about="https://github.com/ghadairesearch/SacredGeoKB#QuranVerse_2_158"><rdf:type rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#QuranVerse" /><sgkb:label_en>Al-Baqarah 2:158</sgkb:label_en><sgkb:label_ar>البقرة 158</sgkb:label_ar><sgkb:surah_number>2</sgkb:surah_number><sgkb:surah_name_ar>البقرة</sgkb:surah_name_ar><sgkb:surah_name_en>Al-Baqarah</sgkb:surah_name_en><sgkb:ayah_number>158</sgkb:ayah_number><sgkb:quran_reference>2:158</sgkb:quran_reference><sgkb:mentions_concept rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#SafaMarwa" /><sgkb:mentions_concept rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#ZoneSemantic_safa" /><sgkb:mentions_concept rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#ZoneSemantic_marwah" /><sgkb:creator>Ghader Kurdi</sgkb:creator><sgkb:title>Al-Baqarah 2:158</sgkb:title><sgkb:data_identifier>QuranVerse_2_158</sgkb:data_identifier><sgkb:publisher>Ghader Kurdi</sgkb:publisher><sgkb:publication_date>2026-07-11</sgkb:publication_date><sgkb:summary>Al-Baqarah 2:158 is an ontology node of type QuranVerse.</sgkb:summary><sgkb:keywords>QuranVerse</sgkb:keywords><sgkb:keywords>QuranVerse_2_158</sgkb:keywords><sgkb:keywords>Al-Baqarah 2:158</sgkb:keywords><sgkb:keywords>البقرة 158</sgkb:keywords><sgkb:keywords>2:158</sgkb:keywords></owl:NamedIndividual><owl:NamedIndividual rdf:about="https://github.com/ghadairesearch/SacredGeoKB#AlIhram"><rdf:type rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Ritual" /><sgkb:label_en>Al-Ihram</sgkb:label_en><sgkb:label_ar>الإحرام</sgkb:label_ar><sgkb:alternative_labels>The State of Consecration</sgkb:alternative_labels><sgkb:alternative_labels>State of Consecration</sgkb:alternative_labels><sgkb:alternative_labels>Ihram</sgkb:alternative_labels><sgkb:definition>Al Ihram is the state of consecration entered by the pilgrim before performing Hajj or Umrah rituals.</sgkb:definition><sgkb:ritual_of rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#HajjJourney" /><sgkb:ritual_of rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#UmrahJourney" /><sgkb:precedes rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Tawaf" /><sgkb:precedes rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#TawafAlIfadhah" /><sgkb:precedes rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#TawafAlWadaa" /><sgkb:precedes rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Sai" /><sgkb:precedes rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#StandingInArafat" /><sgkb:precedes rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#SpendingNightInMuzdalifah" /><sgkb:precedes rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Rami" /><sgkb:precedes rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#SpendingNightInMina" /><sgkb:precedes rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#HairShaving" /><sgkb:associated_place rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#MiqatPlace" /><sgkb:associated_zone_ids>dhul_hulayfah_miqat</sgkb:associated_zone_ids><sgkb:associated_zone_ids>juhfah_miqat</sgkb:associated_zone_ids><sgkb:associated_zone_ids>qarn_al_manazil_miqat</sgkb:associated_zone_ids><sgkb:associated_zone_ids>yalamlam_miqat</sgkb:associated_zone_ids><sgkb:associated_zone_ids>dhat_irq_miqat</sgkb:associated_zone_ids><sgkb:outside_zone_ids>makkah_haram_boundary</sgkb:outside_zone_ids><sgkb:outside_zone_ids>alharam</sgkb:outside_zone_ids><sgkb:spatial_rule>User is inside or near a Miqat geofence. Standard Miqat geofences are outside the Makkah Haram boundary and outside Al-Haram.</sgkb:spatial_rule><sgkb:movement_rule>Movement may be stationary, arrival, or onward movement after entering the Miqat boundary.</sgkb:movement_rule><sgkb:context_state>ihram_preparation_state</sgkb:context_state><sgkb:inferred_need>Ihram Preparation + Guidance</sgkb:inferred_need><sgkb:recommended_message_type>Guidance</sgkb:recommended_message_type><sgkb:priority>High</sgkb:priority><sgkb:evidence_required>journey_type is hajj or umrah</sgkb:evidence_required><sgkb:evidence_required>active zone type is miqat, or user is inside Makkah for Hajj</sgkb:evidence_required><sgkb:evidence_required>boundary state is inside, near, or entered</sgkb:evidence_required><sgkb:knowledge_intent>ihram_guidance</sgkb:knowledge_intent><sgkb:special_rules>{"id": "hajj_ihram_from_makkah_on_tarwiyah", "label_en": "Hajj Ihram from Makkah on the Day of Tarwiyah", "label_ar": "الإحرام بالحج من مكة في يوم التروية", "condition": "The user is in Makkah, has completed Umrah and exited Ihram, or is a Makkah resident intending Hajj.", "temporal_rule": {"calendar": "Hijri", "month": "Dhu al-Hijjah", "preferred_day": 8, "permissible_day": 9}, "spatial_rule": "For this special case, the Ihram place is the user's current place in Makkah, such as residence or accommodation, and is not modeled as alharam or makkah_haram_boundary associated zones.", "context_state": "hajj_ihram_from_makkah_state", "inferred_need": "Ihram Intention + Hajj Preparation", "recommended_message_type": "Guidance", "notes": "If the pilgrim delays entering Ihram for Hajj until the ninth day of Dhu al-Hijjah, this should be treated as permissible and not as an error state."}</sgkb:special_rules><sgkb:mentioned_in_quran rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#QuranVerse_5_95" /><sgkb:creator>Ghader Kurdi</sgkb:creator><sgkb:title>Al-Ihram</sgkb:title><sgkb:data_identifier>AlIhram</sgkb:data_identifier><sgkb:publisher>Ghader Kurdi</sgkb:publisher><sgkb:publication_date>2026-07-11</sgkb:publication_date><sgkb:summary>Al Ihram is the state of consecration entered by the pilgrim before performing Hajj or Umrah rituals.</sgkb:summary><sgkb:keywords>Ritual</sgkb:keywords><sgkb:keywords>AlIhram</sgkb:keywords><sgkb:keywords>Al-Ihram</sgkb:keywords><sgkb:keywords>الإحرام</sgkb:keywords><sgkb:keywords>The State of Consecration</sgkb:keywords><sgkb:keywords>State of Consecration</sgkb:keywords><sgkb:keywords>Ihram</sgkb:keywords></owl:NamedIndividual><owl:NamedIndividual rdf:about="https://github.com/ghadairesearch/SacredGeoKB#Tawaf"><rdf:type rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Ritual" /><sgkb:label_en>Tawaf</sgkb:label_en><sgkb:label_ar>الطواف</sgkb:label_ar><sgkb:definition>The ritual of circumambulation around the Kaaba.</sgkb:definition><sgkb:definition_ar>الطواف نسك يكون بالدوران حول الكعبة سبعة أشواط.</sgkb:definition_ar><sgkb:ritual_of rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#HajjJourney" /><sgkb:ritual_of rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#UmrahJourney" /><sgkb:has_sub_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#TawafAlIfadhah" /><sgkb:has_sub_ritual rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#TawafAlWadaa" /><sgkb:follows rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#AlIhram" /><sgkb:precedes rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Sai" /><sgkb:associated_place rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#KaabaAndMataf" /><sgkb:associated_zone_ids>kaaba</sgkb:associated_zone_ids><sgkb:associated_zone_ids>tawaf</sgkb:associated_zone_ids><sgkb:associated_zone_ids>alharam</sgkb:associated_zone_ids><sgkb:spatial_rule>User is inside or near the Tawaf or Kaaba geofence.</sgkb:spatial_rule><sgkb:movement_rule>Circular trajectory around the Kaaba reference point.</sgkb:movement_rule><sgkb:required_rounds>7</sgkb:required_rounds><sgkb:round_count_rule>Tawaf consists of seven circuits around the Kaaba.</sgkb:round_count_rule><sgkb:sequence_rule>Each complete circuit around the Kaaba counts as one Tawaf round.</sgkb:sequence_rule><sgkb:context_state>ritual_performance_state</sgkb:context_state><sgkb:inferred_need>Ritual Performance + Spiritual Focus</sgkb:inferred_need><sgkb:recommended_message_type>Faith</sgkb:recommended_message_type><sgkb:priority>High</sgkb:priority><sgkb:evidence_required>active zone is kaaba, tawaf, or alharam</sgkb:evidence_required><sgkb:evidence_required>trajectory pattern is tawaf_circular_movement</sgkb:evidence_required><sgkb:evidence_required>movement state is walking</sgkb:evidence_required><sgkb:knowledge_intent>tawaf_faith_guidance</sgkb:knowledge_intent><sgkb:creator>Ghader Kurdi</sgkb:creator><sgkb:title>Tawaf</sgkb:title><sgkb:data_identifier>Tawaf</sgkb:data_identifier><sgkb:publisher>Ghader Kurdi</sgkb:publisher><sgkb:publication_date>2026-07-11</sgkb:publication_date><sgkb:summary>The ritual of circumambulation around the Kaaba.</sgkb:summary><sgkb:keywords>Ritual</sgkb:keywords><sgkb:keywords>Tawaf</sgkb:keywords><sgkb:keywords>الطواف</sgkb:keywords></owl:NamedIndividual><owl:NamedIndividual rdf:about="https://github.com/ghadairesearch/SacredGeoKB#TawafAlIfadhah"><rdf:type rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Ritual" /><sgkb:label_en>Tawaf al-Ifadhah</sgkb:label_en><sgkb:label_ar>طواف الإفاضة</sgkb:label_ar><sgkb:definition>A Hajj Tawaf performed after standing in Arafat and after the pilgrim proceeds from the Hajj sites back to Al-Haram.</sgkb:definition><sgkb:ritual_of rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#HajjJourney" /><sgkb:sub_ritual_of rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#Tawaf" /><sgkb:follows rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#StandingInArafat" /><sgkb:associated_place rdf:resource="https://github.com/ghadairesearch/SacredGeoKB#KaabaAndMataf" /><sgkb:associated_zone_ids>kaaba</sgkb:associated_zone_ids><sgkb:associated_zone_ids>tawaf</sgkb:associated_zone_ids><sgkb:associated_zone_ids>alharam</sgkb:associated_zone_ids><sgkb:temporal_rule>{"calendar": "Hijri", "month": "Dhu al-Hijjah", "day_or_after": 10}</sgkb:temporal_rule><sgkb:spatial_rule>User is inside or near the Tawaf or Kaaba geofence during the Hajj journey after Arafat.</sgkb:spatial_rule><sgkb:movement_rule>Circular trajectory around the Kaaba reference point.</sgkb:movement_rule><sgkb:context_state>tawaf_al_ifadhah_state</sgkb:context_state><sgkb:inferred_need>Ritual Performance + Spiritual Focus</sgkb:inferred_need><sgkb:recommended_message_type>Faith</sgkb:recommended_message_type><sgkb:priority>High</sgkb:priority><sgkb:evidence_required>journey_type is hajj</sgkb:evidence_required><sgkb:evidence_required>active zone is kaaba, tawaf, or alharam</sgkb:evidence_required><sgkb:evidence_required>trajectory pattern is tawaf_circular_movement</sgkb:evidence_required><sgkb:evidence_required>Hijri date is 10 Dhu al-Hijjah or later in the Hajj sequence</sgkb:evidence_required><sgkb:evidence_required>Standing in Arafat has already occurred or current stage follows Arafat</sgkb:evidence_required><sgkb:knowledge_intent>tawaf_ifadhah_guidance</sgkb:knowledge